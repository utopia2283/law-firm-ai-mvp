{
  "statutes": [
    {
      "cap": "Cap. 1",
      "title_tc": "公司法",
      "title_en": "Companies Ordinance",
      "articles": [
        {
          "id": "s14",
          "text": "公司章程細則一經登記，公司即成為合法法人組織，得以公司名義進行各項法律行為。"
        },
        {
          "id": "s157",
          "text": "公司董事對公司及股東负有受信責任，須以公司最佳利益行事，不得利用職權謀取私利。"
        },
        {
          "id": "s163",
          "text": "股份轉讓須符合公司章程細則規定，並由公司登記處辦理過戶手續。"
        }
      ]
    },
    {
      "cap": "Cap. 30",
      "title_tc": "破產條例",
      "title_en": "Bankruptcy Ordinance",
      "articles": [
        {
          "id": "s6",
          "text": "債權人可向高等法院提交破產呈請，須證明債務人無力償還到期債務。"
        },
        {
          "id": "s13",
          "text": "破產管理人負責接管破產人財產，編制債權人清單，並分配資產予債權人。"
        },
        {
          "id": "s30",
          "text": "破產人於破產令生效後不得向外借貸或進行任何信用交易。"
        }
      ]
    },
    {
      "cap": "Cap. 62",
      "title_tc": "證據條例",
      "title_en": "Evidence Ordinance",
      "articles": [
        {
          "id": "s14",
          "text": "任何人均有資格就其所知之事實作證，但法院得酌情決定證據之可接納性。"
        },
        {
          "id": "s21",
          "text": "文件證據須經鑒定真偽，方得呈堂作為有效證據。"
        }
      ]
    },
    {
      "cap": "Cap. 210",
      "title_tc": "不合情理合同條例",
      "title_en": "Unconscionable Contracts Ordinance",
      "articles": [
        {
          "id": "s4",
          "text": "法院若信納某合同或其條款係在考慮到各方之地位及所需货物或服務之性質後而不合情理，可判令該合同或其條款全部或部分無效。"
        }
      ]
    },
    {
      "cap": "Cap. 487",
      "title_tc": "個人資料（私隱）條例",
      "title_en": "Personal Data (Privacy) Ordinance",
      "articles": [
        {
          "id": "s64",
          "text": "資料使用者不得在未獲資料當事人同意之情況下，將其個人資料用於新目的或披露予第三方。"
        }
      ]
    }
  ]
}
