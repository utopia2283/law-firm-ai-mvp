{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    },
    {
      "src": "public/**",
      "use": "static"
    }
  ],
  "routes": [
    {
      "src": "/api/chat",
      "dest": "api/chat.py"
    },
    {
      "src": "/api/dashboard",
      "dest": "api/dashboard.py"
    },
    {
      "src": "/api/files",
      "dest": "api/files.py"
    },
    {
      "src": "/api/generate",
      "dest": "api/generate.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}