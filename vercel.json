{
  "version": 2,
  "functions": {
    "api/*.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/api/chat",
      "dest": "api/chat.py"
    },
    {
      "src": "/api/dashboard",
      "dest": "api/dashboard.py"
    },
    {
      "src": "/api/files",
      "dest": "api/files.py"
    },
    {
      "src": "/api/generate",
      "dest": "api/generate.py"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}